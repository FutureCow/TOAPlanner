generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id
  email        String    @unique
  name         String
  image        String?
  abbreviation String
  isTeacher    Boolean   @default(true)
  isTOA        Boolean   @default(false)
  isAdmin      Boolean   @default(false)
  allowed      Boolean   @default(true)
  defaultPage  String?
  createdAt    DateTime  @default(now())
  requests     Request[]
}

model Request {
  id               String   @id @default(cuid())
  title            String
  klas             String   @default("")
  classroom        String
  date             DateTime
  period           Int
  periodEnd        Int?     // null = same as period; set for multi-hour blocks
  recurringGroupId String?  // links weekly recurring instances
  subject          String
  status           Status   @default(PENDING)
  createdById      String?
  createdBy        User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model SubjectConfig {
  id          String  @id
  name        String
  accentColor String  @default("#2563eb")
  absenceDays Int[]   @default([])
  sortOrder   Int     @default(0)
}

model AppSettings {
  id               Int     @id @default(1)
  registrationOpen Boolean @default(true)
}

enum Status {
  PENDING
  APPROVED_WITH_TOA
  APPROVED_WITHOUT_TOA
  REJECTED
}
