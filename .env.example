# .env.example — kopieer naar .env en vul de waarden in

# ── Single-school setup (niet nodig bij multi-tenant via schools.json) ────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/toa_planner"
SCHOOL_NAME="Mijn School"
ALLOWED_DOMAIN="school.nl"          # meerdere domeinen scheiden met komma

# Google OAuth (single-school fallback)
GOOGLE_CLIENT_ID="from-google-cloud-console"
GOOGLE_CLIENT_SECRET="from-google-cloud-console"

# Azure AD OAuth (optioneel)
AZURE_AD_CLIENT_ID="from-azure-portal"
AZURE_AD_CLIENT_SECRET="from-azure-portal"
AZURE_AD_TENANT_ID="from-azure-portal"


# ── Multi-tenant (bij gebruik van schools.json) ───────────────────────────────
# Welke school als standaard te gebruiken als er geen subdomein is
DEFAULT_SCHOOL="mijnschool"

# ── NextAuth ─────────────────────────────────────────────────────────────────
# Bij multi-tenant wordt NEXTAUTH_URL per request overschreven via de Host-header.
# Stel dit in als fallback voor single-school of lokale development.
# NEXTAUTH_URL="https://yourdomain.nl"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# ── Contactformulier (promopagina) ────────────────────────────────────────────
SMTP_HOST="mail.jouwdomein.nl"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="info@toaplanner.nl"
SMTP_PASS="jouw-smtp-wachtwoord"
CONTACT_EMAIL="info@toaplanner.nl"
